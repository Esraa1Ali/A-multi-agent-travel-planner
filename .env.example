# OpenAI API key used by all LLM-powered agents (GPT-4o / GPT-4o-mini)
OPENAI_API_KEY=sk-your-openai-key-here

# OpenWeatherMap API key used by the weather + enrich agents
# Free key: https://home.openweathermap.org/api_keys
OPENWEATHER_API_KEY=your-openweathermap-key-here

# Flight prices — fast mode (Tavily web search on airline sites).
# Free Tavily key: https://tavily.com/
TAVILY_API_KEY=tvly-your-key-here

# Default price mode for API clients that omit priceMode: true = live (Playwright), false = fast (Tavily).
# The React UI always sends priceMode explicitly. Playwright also needs: playwright install chromium
USE_LIVE_FLIGHTS=true

# Optional: override the default LLM models
OPENAI_MODEL=gpt-4o
OPENAI_FAST_MODEL=gpt-4o-mini
